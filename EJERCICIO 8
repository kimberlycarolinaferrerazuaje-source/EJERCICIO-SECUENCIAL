Algoritmo ComisionesVendedor
	
	Definir sueldo_base, venta1, venta2, venta3 Como Real
	Definir comision1, comision2, comision3, total_comisiones, total_mes Como Real
	
	// Pedir datos
	Escribir "Ingrese el sueldo base:"
	Leer sueldo_base
	
	Escribir "Ingrese el valor de la primera venta:"
	Leer venta1
	
	Escribir "Ingrese el valor de la segunda venta:"
	Leer venta2
	
	Escribir "Ingrese el valor de la tercera venta:"
	Leer venta3
	
	// Calcular comisiones (10%)
	comision1 <- venta1 * 0.10
	comision2 <- venta2 * 0.10
	comision3 <- venta3 * 0.10
	
	// Sumar comisiones
	total_comisiones <- comision1 + comision2 + comision3
	
	// Calcular total del mes
	total_mes <- sueldo_base + total_comisiones
	
	// Mostrar resultados
 escribir "."
 Escribir "Comisión venta 1: ", comision1
	Escribir "Comisión venta 2: ", comision2
	Escribir "Comisión venta 3: ", comision3
	Escribir "Total de comisiones: ", total_comisiones
 escribir "."
	Escribir "Total a recibir en el mes: ", total_mes
	
FinAlgoritmo