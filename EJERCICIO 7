PROCESO CANTIDAD_DE_MINUTOS_QUE_HALLE_HORA_Y_MINUTOS
    //ESTE PROGRAMA CON UNA CANTIDAD X DE MINUTOS VA A HALLAR LA HORA Y MINUTOS EXACTOS
        ESCRIBIR "PROGRAMA QUE INFORMA CON LOS MINUTOS QUE INGRESE, HORA Y MINUTOS EXACTOS"
        LEER MINUTOS
        HORAS <- TRUNC (MINUTOS/60)
        RES <- MINUTOS/60 - HORA
        MINU <- RES + 60
        ESCRIBIR "HORAS : " , HORA
        ESCRIBIR "MINUTOS : " , MINU
FINPROCESO
