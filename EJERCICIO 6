PROCESO HALLAR_LA_MEDIA_DE_TRES_NUMEROS
    //ESTE PROGRAMA HALLA LA MEDIA DE TRES NUMEROS
        ESCRIBIR "ESTE PROGRAMA CALCULA LA MEDIA DE TRES NUMEROS"
        ESCRIBIR "."
        ESCRIBIR "DIJITE EL PRIMER NUMERO"
        LEER NUM1
        ESCRIBIR "DIJITE EL SEGUNDO NUMERO"
        LEER NUM2
        ESCRIBIR "DIJITE EL TERCER NUMERO"
        LEER NUM3
        MEDIA <- (NUM1 + NUM2 + NUM3) / 3
        ESCRIBIR "LA MEDIA DE ESTOS NUMEROS ES " , MEDIA
FINPROCESO
