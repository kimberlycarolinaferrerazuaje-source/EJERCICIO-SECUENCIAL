PROCESO GRADOS_FAHRENHEIT_A_CELSIUS
    //ES UN PROGRAMA QUE PASA DE UN TIPO DE GRADOS A OTRO
    ESCRIBIR "ESTE ES UN PROGRAMA QUE CONVIERTE LOS GRADOS FAHRENHEIT EN GRADOS CELSIUS"
    ESCRIBIR "."
    ESCRIBIR "."
    ESCRIBIR "DIJITE LA TEMPERATURA EN GRADOS FAHRENHEIT"
    LEER FAHRENHEIT
    C <- (F - 32) * 5 / 9
    ESCRIBIR "LA TEMPERATURA EN GRADOS CELSIUS ES " , C
FINPROCESO
